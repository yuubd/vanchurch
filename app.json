{
  "expo": {
    "name": "VanChurch",
    "slug": "vanchurch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vanchurch.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhoneNumberUsageDescription": "Your phone number is used to verify your identity via SMS."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.vanchurch.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "vanchurch",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6637e70f-ad7b-4879-b9f3-d911b0ef7524"
      }
    },
    "owner": "davidgkim93"
  }
}
